<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".NexaApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nexa">

        <!-- MAIN SCREEN -->
        <activity
            android:name=".ui.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <activity
            android:name=".ui.Login"
            android:exported="true" />

        <activity
            android:name=".ui.SignUp"
            android:exported="true" />

        <activity
            android:name=".ui.ForgotPassword"
            android:exported="false" />



        <!-- ✅ JOIN LEDGER SCREEN -->
        <activity
            android:name=".ui.JoinGroupActivity"
            android:exported="false" />

        <!-- Nexa Super App Activities -->
        <activity
            android:name=".ui.DashboardActivity"
            android:exported="false" />
        <activity
            android:name=".ui.CreateLedgerBookActivity"
            android:exported="false" />
        <activity
            android:name=".ui.AddCashbookEntryActivity"
            android:exported="false" />
        <activity
            android:name=".ui.AddSharedExpenseActivity"
            android:exported="false" />
        <activity
            android:name=".ui.SettleUpActivity"
            android:exported="false" />
        <activity
            android:name=".ui.LedgerBookDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ActivityLogActivity"
            android:exported="false" />
        <activity
            android:name=".ui.GlobalSearchActivity"
            android:exported="false"
            android:windowSoftInputMode="stateVisible|adjustResize" />
        <activity
            android:name=".ui.BudgetsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.AddBudgetActivity"
            android:exported="false" />
        <activity
            android:name=".ui.CashCounterActivity"
            android:exported="false" />
        <activity
            android:name=".ui.TasksActivity"
            android:exported="false" />
        <activity
            android:name=".ui.AddTaskActivity"
            android:exported="false" />
        <activity
            android:name=".ui.AddEditNoteActivity"
            android:exported="false" />
        <activity
            android:name=".ui.RemindersActivity"
            android:exported="false" />
        <activity
            android:name=".ui.AddReminderActivity"
            android:exported="false" />
        <activity
            android:name=".ui.ReportsActivity"
            android:exported="false" />


        <!-- Receivers for Reminders -->
        <receiver
            android:name=".notification.ReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".notification.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- SMS Receiver for automatic transactions -->
        <receiver
            android:name=".receiver.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
