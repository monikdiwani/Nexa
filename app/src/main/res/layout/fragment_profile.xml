<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="24dp"
            android:paddingBottom="16dp" />

        <!-- ═════════════════════════════════ -->
        <!-- User Info Card (Avatar + Details) -->
        <!-- ═════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            android:gravity="center">

            <!-- Avatar circle -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center">

                <TextView
                    android:id="@+id/txtProfileInitials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/fab_background"
                    android:gravity="center"
                    android:text="U"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imgProfilePicture"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Display Name -->
            <TextView
                android:id="@+id/txtProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp" />

            <!-- Email -->
            <TextView
                android:id="@+id/txtProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user@example.com"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Member since -->
            <TextView
                android:id="@+id/txtMemberSince"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Member since Jun 2026"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <!-- Edit Profile Button -->
            <TextView
                android:id="@+id/btnEditProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️  Edit Profile"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingVertical="8dp"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/chip_background"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ═════════════════════════ -->
        <!-- Account Section           -->
        <!-- ═════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card"
            android:orientation="vertical"
            android:padding="4dp"
            android:layout_marginBottom="16dp"
            android:elevation="1dp">

            <!-- Change Password Row -->
            <LinearLayout
                android:id="@+id/rowChangePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="🔒"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change Password"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/txtPasswordHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Update your password"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/text_hint"
                    android:textSize="20sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="14dp" />

            <!-- Login Provider Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="🔗"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Login Method"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/txtLoginProvider"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email &amp; Password"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="14dp" />

            <!-- Export Data Row -->
            <LinearLayout
                android:id="@+id/rowExportData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="💾"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Export Data"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Download a copy of your data"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/text_hint"
                    android:textSize="20sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═════════════════════════ -->
        <!-- Preferences Section       -->
        <!-- ═════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preferences"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="1dp">

            <!-- Dark Mode Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🌙"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dark Mode"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginStart="8dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDarkMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:theme="@style/Widget.AppCompat.CompoundButton.Switch" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Morning Summary Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="☀️"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Morning Digest (8:00 AM)"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginStart="8dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchMorningDigest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Night Summary Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🌜"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Evening Digest (9:30 PM)"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginStart="8dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchEveningDigest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- App Lock Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="App Lock (Biometric / PIN)"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginStart="8dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAppLock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Battery Optimization Settings -->
            <LinearLayout
                android:id="@+id/rowBatteryOptimization"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🔋"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Allow Background Execution"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginStart="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/text_hint"
                    android:textSize="20sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Notification Settings -->
            <LinearLayout
                android:id="@+id/rowNotificationSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🔔"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Notification Settings"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginStart="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/text_hint"
                    android:textSize="20sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- SMS Auto-Add Toggle -->
            <LinearLayout
                android:id="@+id/rowSmsAutoAdd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="💬"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SMS Auto-Add Transactions"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-detect bank SMS and add to ledger"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchSmsAutoAdd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </LinearLayout>

        <!-- ═════════════════════════ -->
        <!-- Legal & Help              -->
        <!-- ═════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Legal &amp; Help"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card"
            android:orientation="vertical"
            android:padding="4dp"
            android:layout_marginBottom="16dp"
            android:elevation="1dp">

            <TextView
                android:id="@+id/btnAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="About Nexa"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:padding="14dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="14dp" />
            <TextView
                android:id="@+id/btnFAQ"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FAQ"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:padding="14dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="14dp" />
            <TextView
                android:id="@+id/btnPrivacyPolicy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Privacy Policy"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:padding="14dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Logout button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Log Out"
            android:textColor="@color/white"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/accent_negative"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Delete Account button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDeleteAccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete Account"
            android:textColor="@color/accent_negative"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/surface_primary"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nexa v1.0 • Made with ❤️"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
