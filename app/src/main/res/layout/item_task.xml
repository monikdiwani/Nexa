<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/rounded_card"
    android:padding="16dp"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    android:elevation="1dp">

    <!-- Checkbox for completion -->
    <CheckBox
        android:id="@+id/cbTaskStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/primary" />

    <!-- Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/txtTaskTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Task Title"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtTaskDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Due Oct 12"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/layoutSubtaskProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/pbSubtasks"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="@color/primary"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/txtSubtaskCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/2"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Badges Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <!-- Important Indicator -->
        <TextView
            android:id="@+id/txtTaskImportant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="4dp" />

        <!-- Priority Indicator -->
        <TextView
            android:id="@+id/txtTaskPriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HIGH"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/chip_background"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" />

        <!-- Repeat Indicator -->
        <TextView
            android:id="@+id/txtTaskRepeat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔁"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>
