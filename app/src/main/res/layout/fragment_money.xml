<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Money"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <!-- Net Balance Card -->
        <LinearLayout
            android:id="@+id/cardNetBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_gradient_indigo"
            android:orientation="vertical"
            android:padding="22dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Net Balance"
                android:textSize="13sp"
                android:textColor="#BBFFFFFF" />

            <TextView
                android:id="@+id/txtNetBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0.00"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginTop="2dp" />

            <!-- Row: Cash In / Cash Out / You Owe / Owed -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <!-- Cash In -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▲ Income"
                        android:textSize="10sp"
                        android:textColor="#99FFFFFF" />

                    <TextView
                        android:id="@+id/txtMoneyIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#80FFAA" />
                </LinearLayout>

                <!-- Cash Out -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▼ Expense"
                        android:textSize="10sp"
                        android:textColor="#99FFFFFF" />

                    <TextView
                        android:id="@+id/txtMoneyOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FF8A80" />
                </LinearLayout>

                <!-- You Owe -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤 You Owe"
                        android:textSize="10sp"
                        android:textColor="#99FFFFFF" />

                    <TextView
                        android:id="@+id/txtYouOwe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFCC80" />
                </LinearLayout>

                <!-- Owed to you -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💰 Owed"
                        android:textSize="10sp"
                        android:textColor="#99FFFFFF" />

                    <TextView
                        android:id="@+id/txtOwedToYou"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#80D8FF" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Embedded CashbookFragment -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/cashbookFragmentContainer"
            android:name="com.example.frienddebt.ui.fragment.CashbookFragment"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
