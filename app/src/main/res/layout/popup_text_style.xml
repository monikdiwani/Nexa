<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_popup_rounded"
    android:paddingVertical="8dp"
    android:elevation="12dp">

    <!-- Heading 1 -->
    <TextView
        android:id="@+id/styleHeading1"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Heading 1"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground" />

    <!-- Heading 2 -->
    <TextView
        android:id="@+id/styleHeading2"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Heading 2"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground" />

    <!-- Heading 3 -->
    <TextView
        android:id="@+id/styleHeading3"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Heading 3"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="4dp" />

    <!-- Body 1 -->
    <TextView
        android:id="@+id/styleBody1"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Body 1"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground" />

    <!-- Body 2 -->
    <TextView
        android:id="@+id/styleBody2"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Body 2"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground" />

</LinearLayout>
