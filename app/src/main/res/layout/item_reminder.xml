<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Priority color bar -->
        <View
            android:id="@+id/viewPriorityBar"
            android:layout_width="4dp"
            android:layout_height="56dp"
            android:background="@color/priority_medium"
            android:layout_marginEnd="14dp" />

        <!-- Left: emoji icon -->
        <TextView
            android:id="@+id/txtReminderIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="⏰"
            android:textSize="22sp"
            android:background="@color/primary_surface"
            android:layout_marginEnd="12dp" />

        <!-- Content block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtReminderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reminder Title"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txtReminderMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No description"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

            <!-- Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/txtReminderTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today at 09:00 AM"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtReminderRepeat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • 🔁 DAILY"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/txtReminderLinkedTask"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • 🔗 Task"
                    android:textColor="@color/secondary"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Countdown chip -->
            <TextView
                android:id="@+id/txtReminderCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In 2 hrs 30 min"
                android:textColor="@color/accent_warning"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Right: actions block -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end|center_vertical"
            android:layout_marginStart="8dp">
            
            <TextView
                android:id="@+id/txtReminderPriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MED"
                android:textColor="@color/on_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@color/priority_medium"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />

            <ImageView
                android:id="@+id/btnMarkReminderDone"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:padding="6dp"
                android:src="@drawable/ic_check"
                android:background="@drawable/circle_background_light"
                app:tint="@color/primary"
                android:contentDescription="Mark Done" />
                
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
