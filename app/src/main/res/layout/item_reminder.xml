<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/rounded_card"
    android:padding="16dp"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    android:elevation="1dp">

    <!-- Category Icon -->
    <TextView
        android:id="@+id/txtReminderIcon"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/chip_background"
        android:gravity="center"
        android:text="⏰"
        android:textSize="20sp" />

    <!-- Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="10dp">

        <TextView
            android:id="@+id/txtReminderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reminder Title"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtReminderMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Message body..."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/txtReminderCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In 2 hours"
                android:textColor="@color/accent_warning"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/txtReminderTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Oct 12, 2023 at 5:00 PM"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

            <TextView
                android:id="@+id/txtReminderRepeat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • 🔁 Daily"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />
                
            <TextView
                android:id="@+id/txtReminderLinkedTask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • 🔗 Task"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Priority Badge -->
    <TextView
        android:id="@+id/txtReminderPriority"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HIGH"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/chip_background"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp" />

</LinearLayout>
