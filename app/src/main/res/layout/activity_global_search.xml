<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary"
    android:padding="16dp">

    <!-- Header / Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:tint="@color/text_primary" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/edit_text_background"
            android:hint="Search anything..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="16dp"
            android:inputType="textNoSuggestions"
            android:maxLines="1"
            android:imeOptions="actionSearch" />
    </LinearLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="@drawable/rounded_button"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/chipTasks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tasks"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="@drawable/chip_background"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/chipNotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notes"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="@drawable/chip_background"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/chipMoney"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Money"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="@drawable/chip_background"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/chipReminders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reminders"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="@drawable/chip_background"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/chipLedgers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ledgers"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="@drawable/chip_background"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Loading State -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="gone" />

    <!-- Results List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layoutAnimation="@anim/list_fall_down"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="48sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try searching by amount, title, or category."
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:textAlignment="center"/>
    </LinearLayout>

</LinearLayout>
