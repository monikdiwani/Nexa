<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Primary Top Bar -->
    <LinearLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_edit" 
            android:rotation="180"
            app:tint="@android:color/white"
            android:contentDescription="Back" />

        <EditText
            android:id="@+id/etNoteTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Title"
            android:textColorHint="#555555"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:inputType="textCapSentences|textNoSuggestions"
            android:maxLines="1"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/btnReadMode"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@android:color/white"
            android:contentDescription="Read Mode" />

        <ImageButton
            android:id="@+id/btnAddAttachment"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_input_add"
            app:tint="@android:color/white"
            android:contentDescription="Add Attachment" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            app:tint="@android:color/white"
            android:contentDescription="Menu" />
    </LinearLayout>

    <!-- Secondary Top Bar (Drawing & Undo/Redo) -->
    <LinearLayout
        android:id="@+id/layoutDrawingBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/layoutTopBar"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="#222222">

        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="#AAAAAA" />

        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@android:color/white" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#555555" />

        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:rotationY="180"
            app:tint="#555555" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        
        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#AAAAAA" />
    </LinearLayout>

    <!-- Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutDrawingBar"
        android:layout_above="@id/layoutFormattingBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/etNoteContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:gravity="top|start"
                android:hint=""
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:lineSpacingExtra="4dp"
                android:inputType="textMultiLine|textCapSentences|textNoSuggestions" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Formatting Toolbar -->
    <HorizontalScrollView
        android:id="@+id/layoutFormattingBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:background="#222222"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <ImageButton
                android:id="@+id/btnFormatTask"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="@android:color/white" />

            <Button
                android:id="@+id/btnFormatBold"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="48dp"
                android:text="B"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <Button
                android:id="@+id/btnFormatItalic"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="48dp"
                android:text="I"
                android:textStyle="italic"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <Button
                android:id="@+id/btnFormatUnderline"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="48dp"
                android:text="U"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <Button
                android:id="@+id/btnFormatStrikethrough"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="48dp"
                android:text="S"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>
                
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#444444"
                android:layout_marginHorizontal="8dp"/>

            <Button
                android:id="@+id/btnFormatListNumber"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="48dp"
                android:text="1."
                android:textSize="16sp"
                android:textColor="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <Button
                android:id="@+id/btnFormatBullet"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="48dp"
                android:text="•"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#444444"
                android:layout_marginHorizontal="8dp"/>

            <Button
                android:id="@+id/btnFormatAlignLeft"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="48dp"
                android:text="L"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>
                
            <Button
                android:id="@+id/btnFormatAlignCenter"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="48dp"
                android:text="C"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>
                
            <Button
                android:id="@+id/btnFormatAlignRight"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="48dp"
                android:text="R"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

        </LinearLayout>
    </HorizontalScrollView>

</RelativeLayout>
