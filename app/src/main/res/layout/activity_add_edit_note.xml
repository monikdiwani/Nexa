<?xml version="1.0" encoding="utf-8"?>
<!-- Root is LinearLayout (vertical) so the formatting bar is ALWAYS above the keyboard -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/editorRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- ═══════════ ROW 1: Primary Top Bar ═══════════ -->
    <LinearLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="@color/background_primary">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary"
            android:contentDescription="Back" />

        <EditText
            android:id="@+id/etNoteTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Title"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:inputType="textCapSentences|textNoSuggestions"
            android:maxLines="1"
            android:imeOptions="actionNext"
            android:layout_marginStart="4dp" />

        <!-- Folder chip: shows Personal / Work, tap to change -->
        <TextView
            android:id="@+id/btnFolderChip"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Personal"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:background="@drawable/bg_chip_outlined"
            android:paddingHorizontal="10dp"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:contentDescription="Select folder" />

        <ImageButton
            android:id="@+id/btnAddAttachment"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/toolbar_icon"
            android:contentDescription="Add Attachment" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            app:tint="@color/toolbar_icon"
            android:contentDescription="More Options" />
    </LinearLayout>

    <!-- ═══════════ ROW 2: Tool Mode Bar (Samsung Notes style) ═══════════ -->
    <LinearLayout
        android:id="@+id/layoutDrawingBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface_drawing_bar">

        <!-- Keyboard (text mode — active, highlighted) -->
        <ImageButton
            android:id="@+id/btnToolKeyboard"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_tool_active"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/primary"
            android:layout_marginStart="6dp"
            android:contentDescription="Text mode" />

        <!-- Pen -->
        <ImageButton
            android:id="@+id/btnToolPen"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/toolbar_icon"
            android:layout_marginStart="4dp"
            android:contentDescription="Pen" />

        <!-- Highlighter -->
        <ImageButton
            android:id="@+id/btnToolHighlighter"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#F5C842"
            android:layout_marginStart="4dp"
            android:contentDescription="Highlighter" />

        <!-- Eraser -->
        <ImageButton
            android:id="@+id/btnToolEraser"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/toolbar_icon"
            android:layout_marginStart="4dp"
            android:contentDescription="Eraser" />

        <!-- Lasso/Select -->
        <ImageButton
            android:id="@+id/btnToolLasso"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_crop"
            app:tint="@color/toolbar_icon"
            android:layout_marginStart="4dp"
            android:contentDescription="Select" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Undo -->
        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/toolbar_icon"
            android:contentDescription="Undo" />

        <!-- Redo -->
        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:rotationY="180"
            app:tint="@color/toolbar_icon"
            android:contentDescription="Redo" />

        <!-- Marker -->
        <ImageButton
            android:id="@+id/btnToolMarker"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/primary"
            android:layout_marginEnd="6dp"
            android:contentDescription="Marker" />
    </LinearLayout>

    <!-- ═══════════ CONTENT AREA (weight=1 = fills all space between toolbars) ═══════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Attached Images Strip -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal"
                android:visibility="gone"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Main Content Editor -->
            <EditText
                android:id="@+id/etNoteContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Start writing..."
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="16sp"
                android:lineSpacingExtra="5dp"
                android:background="@null"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top"
                android:minHeight="400dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ═══════════ BOTTOM: Formatting Bar (always visible above keyboard) ═══════════ -->
    <HorizontalScrollView
        android:id="@+id/layoutFormattingBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface_drawing_bar"
        android:scrollbars="none"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <!-- ☑ Checklist (inline) -->
            <ImageButton
                android:id="@+id/btnFormatTask"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/checkbox_off_background"
                app:tint="@color/text_primary"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:contentDescription="Insert checklist item" />

            <View android:layout_width="1dp" android:layout_height="24dp"
                android:background="@color/divider" android:layout_marginHorizontal="2dp" />

            <!-- T = Font Colour -->
            <Button
                android:id="@+id/btnFontColor"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="T"
                android:textSize="18sp"
                android:textStyle="bold"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:textColor="@color/primary" />

            <!-- T▣ = Font Background -->
            <Button
                android:id="@+id/btnFontBg"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="T▣"
                android:textSize="14sp"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:textColor="@color/text_primary" />

            <!-- Aa = Text Style -->
            <Button
                android:id="@+id/btnTextStyle"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="Aa"
                android:textSize="15sp"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:textColor="@color/text_primary" />

            <!-- 15▼ = Font Size -->
            <Button
                android:id="@+id/btnFontSize"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:paddingHorizontal="6dp"
                android:text="16▼"
                android:textSize="13sp"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:textColor="@color/text_primary" />

            <View android:layout_width="1dp" android:layout_height="24dp"
                android:background="@color/divider" android:layout_marginHorizontal="2dp" />

            <!-- B = Bold -->
            <Button
                android:id="@+id/btnFormatBold"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="B"
                android:textStyle="bold"
                android:textSize="18sp"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:textColor="@color/text_primary" />

            <!-- I = Italic -->
            <Button
                android:id="@+id/btnFormatItalic"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="I"
                android:textStyle="italic"
                android:textSize="18sp"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:textColor="@color/text_primary" />

            <!-- U = Underline -->
            <Button
                android:id="@+id/btnFormatUnderline"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="U"
                android:textSize="18sp"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:textColor="@color/text_primary" />

            <View android:layout_width="1dp" android:layout_height="24dp"
                android:background="@color/divider" android:layout_marginHorizontal="2dp" />

            <!-- → = More / Overflow -->
            <ImageButton
                android:id="@+id/btnFormatMore"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/text_primary"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:contentDescription="More formatting options" />

        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>
