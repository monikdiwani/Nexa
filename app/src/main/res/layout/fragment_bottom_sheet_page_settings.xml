<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@color/divider" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Page settings"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp" />

    <!-- Font size -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FONT SIZE"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:letterSpacing="0.1"
        android:paddingHorizontal="20dp"
        android:paddingBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp">

        <SeekBar
            android:id="@+id/seekFontSize"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="14"
            android:progress="2"
            android:progressTint="@color/primary"
            android:thumbTint="@color/primary" />

        <TextView
            android:id="@+id/txtFontSizeValue"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="16sp"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- Line spacing -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LINE SPACING"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:letterSpacing="0.1"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:id="@+id/spacingCompact"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/rounded_card"
            android:elevation="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Compact"
                android:textSize="12sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/spacingNormal"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/rounded_card"
            android:elevation="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Normal"
                android:textSize="12sp"
                android:textColor="@color/primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/spacingRelaxed"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/rounded_card"
            android:elevation="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Relaxed"
                android:textSize="12sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

    </LinearLayout>

    <!-- Paper type -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PAPER TYPE"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:letterSpacing="0.1"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <LinearLayout android:id="@+id/styleBlank"
            android:layout_width="0dp" android:layout_height="64dp"
            android:layout_weight="1" android:layout_margin="4dp"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/rounded_card">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Blank" android:textSize="11sp" android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout android:id="@+id/styleLined"
            android:layout_width="0dp" android:layout_height="64dp"
            android:layout_weight="1" android:layout_margin="4dp"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/rounded_card">
            <View android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/bg_note_lined" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lined" android:textSize="11sp" android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout android:id="@+id/styleGrid"
            android:layout_width="0dp" android:layout_height="64dp"
            android:layout_weight="1" android:layout_margin="4dp"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/rounded_card">
            <View android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/bg_note_grid" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Grid" android:textSize="11sp" android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout android:id="@+id/styleDotted"
            android:layout_width="0dp" android:layout_height="64dp"
            android:layout_weight="1" android:layout_margin="4dp"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/rounded_card">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dotted" android:textSize="11sp" android:textColor="@color/text_primary" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
