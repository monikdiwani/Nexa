<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/rounded_card"
    android:padding="16dp"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    android:elevation="1dp">

    <!-- Category Icon -->
    <TextView
        android:id="@+id/txtEntryIcon"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/chip_background"
        android:gravity="center"
        android:text="💰"
        android:textSize="20sp" />

    <!-- Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="10dp">

        <TextView
            android:id="@+id/txtEntryParticulars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Particulars"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/txtEntryDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oct 12, 2023"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtEntryCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Other"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtEntryAddedBy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Added by: Unknown"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Amount and Medium -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/txtEntryAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+₹0.00"
            android:textColor="@color/accent_positive"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtEntryMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💵 Cash"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />
            
        <TextView
            android:id="@+id/txtRunningBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bal: ₹0.00"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnEntryOptions"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Options"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_more"
        android:tint="@color/text_secondary" />

</LinearLayout>
