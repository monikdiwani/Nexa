<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_card"
    android:padding="16dp"
    android:layout_margin="6dp"
    android:elevation="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/txtNoteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/imgPinned"
            android:text="Note Title"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/imgPinned"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_pin"
            app:tint="@color/primary"
            android:visibility="gone" />
    </RelativeLayout>

    <TextView
        android:id="@+id/txtNoteContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This is a quick preview of the note content..."
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:maxLines="4"
        android:ellipsize="end"
        android:layout_marginTop="6dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/txtNoteLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Label"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:background="@drawable/chip_background"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txtNoteDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Oct 12, 2023"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

</LinearLayout>
