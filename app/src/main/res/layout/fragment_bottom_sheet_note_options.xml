<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bottom_sheet_bg">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/btnChangeColor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Change Background Color"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:paddingVertical="16dp"
        android:drawableStart="@android:drawable/ic_menu_edit"
        android:drawablePadding="16dp"
        android:background="?attr/selectableItemBackground"/>

    <TextView
        android:id="@+id/btnChangeFolder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Change Folder &amp; Tags"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:paddingVertical="16dp"
        android:drawableStart="@android:drawable/ic_menu_sort_by_size"
        android:drawablePadding="16dp"
        android:background="?attr/selectableItemBackground"/>

    <TextView
        android:id="@+id/btnVersionHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Version History"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:paddingVertical="16dp"
        android:drawableStart="@android:drawable/ic_menu_recent_history"
        android:drawablePadding="16dp"
        android:background="?attr/selectableItemBackground"/>

    <TextView
        android:id="@+id/btnShare"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share Note"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:paddingVertical="16dp"
        android:drawableStart="@android:drawable/ic_menu_share"
        android:drawablePadding="16dp"
        android:background="?attr/selectableItemBackground"/>

    <TextView
        android:id="@+id/btnArchive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Archive"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:paddingVertical="16dp"
        android:drawableStart="@android:drawable/ic_menu_save"
        android:drawablePadding="16dp"
        android:background="?attr/selectableItemBackground"/>

    <TextView
        android:id="@+id/btnTrash"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Move to Trash"
        android:textSize="16sp"
        android:textColor="#D32F2F"
        android:paddingVertical="16dp"
        android:drawableStart="@android:drawable/ic_menu_delete"
        android:drawableTint="#D32F2F"
        android:drawablePadding="16dp"
        android:background="?attr/selectableItemBackground"/>

</LinearLayout>
