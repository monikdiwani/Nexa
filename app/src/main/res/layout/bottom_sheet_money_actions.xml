<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bottom_sheet_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Money Actions"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/btnActionAddIncome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Cash In (Income)"
        android:textSize="16sp"
        android:paddingVertical="14dp"
        android:textColor="@color/text_primary"
        android:background="?attr/selectableItemBackground" />

    <TextView
        android:id="@+id/btnActionAddExpense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Cash Out (Expense)"
        android:textSize="16sp"
        android:paddingVertical="14dp"
        android:textColor="@color/text_primary"
        android:background="?attr/selectableItemBackground" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginVertical="8dp" />

    <TextView
        android:id="@+id/btnActionAddSharedExpense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Shared Expense"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingVertical="14dp"
        android:textColor="@color/primary"
        android:background="?attr/selectableItemBackground" />

    <TextView
        android:id="@+id/btnActionSettleUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settle Up"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingVertical="14dp"
        android:textColor="@color/accent_positive"
        android:background="?attr/selectableItemBackground" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginVertical="8dp" />

    <TextView
        android:id="@+id/btnActionCreateLedger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create Ledger"
        android:textSize="16sp"
        android:paddingVertical="14dp"
        android:textColor="@color/text_secondary"
        android:background="?attr/selectableItemBackground" />

    <TextView
        android:id="@+id/btnActionJoinLedger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Join Ledger via Code"
        android:textSize="16sp"
        android:paddingVertical="14dp"
        android:textColor="@color/text_secondary"
        android:background="?attr/selectableItemBackground" />

</LinearLayout>
