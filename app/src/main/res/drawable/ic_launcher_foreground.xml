<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left vertical bar (Gradient Indigo to Violet) -->
    <path
        android:pathData="M29,24 L42,24 L42,84 L29,84 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="29"
                android:startY="24"
                android:endX="42"
                android:endY="84"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF6366F1" />
                <item android:offset="1.0" android:color="#FFA855F7" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Diagonal folding piece (Gradient Violet to Pink) -->
    <path
        android:pathData="M29,24 L42,24 L79,84 L66,84 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="29"
                android:startY="24"
                android:endX="79"
                android:endY="84"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF818CF8" />
                <item android:offset="0.5" android:color="#FFA855F7" />
                <item android:offset="1.0" android:color="#FFEC4899" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right vertical bar (Gradient Pink to Indigo) -->
    <path
        android:pathData="M66,24 L79,24 L79,84 L66,84 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="66"
                android:startY="24"
                android:endX="79"
                android:endY="84"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFEC4899" />
                <item android:offset="1.0" android:color="#FF6366F1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Accent glowing dot (Top Right) -->
    <path
        android:pathData="M85,22 A4,4 0 1 1 85,21.99 Z"
        android:fillColor="#FFFBBF24" />

</vector>